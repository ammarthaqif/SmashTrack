rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tournaments
    // Document ID: tournamentId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - organizerId: string (required, auth.uid)
    //   - date: string (optional, ISO 8601)
    //   - venue: string (optional, 1-200 chars)
    //   - numCourts: number (required, 1-50)
    //   - courtNames: map (optional)
    //   - pin: string (legacy)
    //   - umpirePin: string (required, 4-10 chars)
    //   - audiencePin: string (required, 4-10 chars)
    //   - logoUrl: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: tournaments/{tournamentId}/matches
    // Document ID: matchId
    // Fields:
    //   - tournamentId: string (required)
    //   - courtNumber: number (optional)
    //   - player1: string (required)
    //   - player2: string (required)
    //   - player1Id: string (optional)
    //   - player2Id: string (optional)
    //   - score1: number (required, >= 0)
    //   - score2: number (required, >= 0)
    //   - status: string (required, ['scheduled', 'ongoing', 'completed'])
    //   - umpireId: string (optional)
    //   - umpireName: string (optional)
    //   - isDoubles: boolean (optional)
    //   - server: string (optional)
    //   - sets: list (optional)
    //
    // Collection: tournaments/{tournamentId}/players
    // Document ID: playerId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - tournamentId: string (required)
    //   - category: string (required, ['singles', 'doubles', 'mixed'])
    //   - stats: map (optional)
    //
    // Collection: tournaments/{tournamentId}/umpires
    // Document ID: umpireId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - tournamentId: string (required)
    //
    // Collection: licenses
    // Document ID: licenseId
    // Fields:
    //   - organizerEmail: string (required)
    //   - accessPin: string (required)
    //   - type: string (required, ['1day', 'multi', 'monthly', 'annual'])
    //   - validUntil: string (required, ISO 8601)
    //   - status: string (required, ['active', 'expired', 'pending'])
    //   - usedByUid: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
         (request.auth.token.email == "ammarthaqif.ar@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOrganizer(tournamentId) {
      return isAuthenticated() && (resource == null || resource.data.organizerId == request.auth.uid || isAdmin());
    }

    function isValidTournament(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.organizerId is string && data.organizerId == request.auth.uid &&
             data.umpirePin is string && data.umpirePin.size() >= 4 && data.umpirePin.size() <= 10 &&
             data.audiencePin is string && data.audiencePin.size() >= 4 && data.audiencePin.size() <= 10 &&
             data.numCourts is number && data.numCourts >= 1 && data.numCourts <= 50 &&
             (!('venue' in data) || (data.venue is string && data.venue.size() <= 200)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000));
    }

    function isValidMatch(data) {
      return data.tournamentId is string &&
             data.player1 is string && data.player1.size() >= 1 && data.player1.size() <= 100 &&
             data.player2 is string && data.player2.size() >= 1 && data.player2.size() <= 100 &&
             data.score1 is number && data.score1 >= 0 && data.score1 <= 1000 &&
             data.score2 is number && data.score2 >= 0 && data.score2 <= 1000 &&
             data.status in ['scheduled', 'ongoing', 'completed'] &&
             (!('umpireName' in data) || (data.umpireName is string && data.umpireName.size() <= 100));
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.tournamentId is string &&
             data.category in ['singles', 'doubles', 'mixed'];
    }

    function isValidUmpire(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.tournamentId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tournaments/{tournamentId} {
      // Anyone can read/list tournaments (needed for PIN search and audience view)
      allow read, list: if true;
      
      allow create: if isAuthenticated() && isValidTournament(request.resource.data);
      allow update: if isOrganizer(tournamentId) && isValidTournament(request.resource.data);
      allow delete: if isOrganizer(tournamentId);

      match /matches/{matchId} {
        allow read: if true;
        allow create: if isOrganizer(tournamentId) && isValidMatch(request.resource.data);
        // Umpires can update matches if they have the PIN (checked client-side, but rules allow any update for now if valid)
        // Ideally we'd check the PIN here, but it's in the parent doc.
        allow update: if (isOrganizer(tournamentId) || true) && isValidMatch(request.resource.data);
        allow delete: if isOrganizer(tournamentId);
      }

      match /players/{playerId} {
        allow read: if true;
        allow create: if isOrganizer(tournamentId) && isValidPlayer(request.resource.data);
        allow update: if isOrganizer(tournamentId) && isValidPlayer(request.resource.data);
        allow delete: if isOrganizer(tournamentId);
      }

      match /umpires/{umpireId} {
        allow read: if true;
        allow create: if isOrganizer(tournamentId) && isValidUmpire(request.resource.data);
        allow update: if isOrganizer(tournamentId) && isValidUmpire(request.resource.data);
        allow delete: if isOrganizer(tournamentId);
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
        (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
    }

    match /licenses/{licenseId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.organizerEmail == request.auth.token.email);
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read: if isAdmin();
    }
  }
}
