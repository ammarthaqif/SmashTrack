rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tournaments
    // Document ID: tournamentId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - organizerId: string (required, auth.uid)
    //   - date: string (optional, ISO 8601)
    //   - venue: string (optional, 1-200 chars)
    //   - numCourts: number (required, 1-50)
    //   - courtNames: map (optional)
    //   - pin: string (legacy)
    //   - umpirePin: string (required, 4-10 chars)
    //   - audiencePin: string (required, 4-10 chars)
    //   - logoUrl: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: tournaments/{tournamentId}/matches
    // Document ID: matchId
    // Fields:
    //   - tournamentId: string (required)
    //   - courtNumber: number (optional)
    //   - player1: string (required)
    //   - player2: string (required)
    //   - player1Id: string (optional)
    //   - player2Id: string (optional)
    //   - score1: number (required, >= 0)
    //   - score2: number (required, >= 0)
    //   - status: string (required, ['scheduled', 'ongoing', 'completed'])
    //   - umpireId: string (optional)
    //   - umpireName: string (optional)
    //   - isDoubles: boolean (optional)
    //   - server: string (optional)
    //   - sets: list (optional)
    //
    // Collection: tournaments/{tournamentId}/players
    // Document ID: playerId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - tournamentId: string (required)
    //   - category: string (required, ['singles', 'doubles', 'mixed'])
    //   - stats: map (optional)
    //
    // Collection: tournaments/{tournamentId}/umpires
    // Document ID: umpireId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - tournamentId: string (required)
    //
    // Collection: licenses
    // Document ID: licenseId
    // Fields:
    //   - organizerEmail: string (required)
    //   - accessPin: string (required)
    //   - type: string (required, ['1day', 'multi', 'monthly', 'annual'])
    //   - validUntil: string (required, ISO 8601)
    //   - status: string (required, ['active', 'expired', 'pending'])
    //   - usedByUid: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "ammarthaqif.ar@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'))
      );
    }

    function isTournamentOwner(tournamentId) {
      return isAuthenticated() && (
        (get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid) || 
        isAdmin()
      );
    }

    function isMatchEditor(tournamentId) {
      return isAuthenticated(); // Simplified: anyone authenticated (including anonymous umpires)
    }

    function isValidTournament(data) {
      return isAdmin() || (
        data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
        data.organizerId is string && data.organizerId == request.auth.uid &&
        data.umpirePin is string && data.umpirePin.size() >= 4 && data.umpirePin.size() <= 10 &&
        data.audiencePin is string && data.audiencePin.size() >= 4 && data.audiencePin.size() <= 10 &&
        data.numCourts is number && data.numCourts >= 1 && data.numCourts <= 50 &&
        (!('venue' in data) || (data.venue is string && data.venue.size() <= 200)) &&
        (!('date' in data) || (data.date is string && data.date.size() <= 100)) &&
        (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000))
      );
    }

    function isValidMatch(data) {
      return isAdmin() || (
        data.tournamentId is string &&
        data.player1 is string && data.player1.size() >= 1 && data.player1.size() <= 100 &&
        data.player2 is string && data.player2.size() >= 1 && data.player2.size() <= 100 &&
        data.score1 is number && data.score1 >= 0 && data.score1 <= 1000 &&
        data.score2 is number && data.score2 >= 0 && data.score2 <= 1000 &&
        data.status in ['scheduled', 'ongoing', 'completed'] &&
        (!('umpireName' in data) || (data.umpireName is string && data.umpireName.size() <= 100)) &&
        (!('stage' in data) || (data.stage is string && data.stage.size() <= 50)) &&
        (!('roundName' in data) || (data.roundName is string && data.roundName.size() <= 100)) &&
        (!('groupName' in data) || (data.groupName is string && data.groupName.size() <= 100)) &&
        (!('category' in data) || (data.category is string && data.category.size() <= 50))
      );
    }

    function isValidPlayer(data) {
      return isAdmin() || (
        data.name is string && data.name.size() >= 1 && data.name.size() <= 200 &&
        data.tournamentId is string &&
        data.category in ['singles', 'doubles', 'mixed'] &&
        (!('isTeam' in data) || data.isTeam is bool) &&
        (!('teamName' in data) || (data.teamName is string && data.teamName.size() <= 200)) &&
        (!('members' in data) || data.members is list) &&
        (!('stats' in data) || data.stats is map)
      );
    }

    function isValidUmpire(data) {
      return isAdmin() || (
        data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
        data.tournamentId is string &&
        (!('isAvailable' in data) || data.isAvailable is bool) &&
        (!('preferredCourts' in data) || data.preferredCourts is list)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

      match /tournaments/{tournamentId} {
      // Anyone can read/list tournaments (needed for PIN search and audience view)
      allow read, list: if true;
      
      allow create: if (isAdmin() || isAuthenticated()) && isValidTournament(request.resource.data);
      allow update: if isTournamentOwner(tournamentId) && isValidTournament(request.resource.data);
      allow delete: if isTournamentOwner(tournamentId);

      match /matches/{matchId} {
        allow read: if true;
        allow create: if isTournamentOwner(tournamentId) && isValidMatch(request.resource.data);
        allow update: if isTournamentOwner(tournamentId) || isMatchEditor(tournamentId);
        allow delete: if isTournamentOwner(tournamentId);
      }

      match /players/{playerId} {
        allow read: if true;
        // PUBLIC REGISTRATION: any authenticated user (including anonymous) can create a player
        allow create: if isAuthenticated() && isValidPlayer(request.resource.data);
        allow update: if isTournamentOwner(tournamentId);
        allow delete: if isTournamentOwner(tournamentId);
      }

      match /umpires/{umpireId} {
        allow read: if true;
        allow create: if isTournamentOwner(tournamentId) && isValidUmpire(request.resource.data);
        allow update: if isTournamentOwner(tournamentId) || isAuthenticated(); // Umpires can update their own status
        allow delete: if isTournamentOwner(tournamentId);
      }
    }

    match /users/{userId} {
      allow read, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin() || (isOwner(userId) && 
        (!('role' in request.resource.data) || 
         request.resource.data.role == 'user' || 
         request.resource.data.role == 'organizer'));
    }

    match /licenses/{licenseId} {
      allow read, list: if isAdmin() || (isAuthenticated() && resource.data.organizerEmail == request.auth.token.email);
      // Allow anonymous users to query a specific license if they know the email and PIN
      allow list: if isAuthenticated() && (
        (request.auth.token.firebase.sign_in_provider == 'anonymous' && 
         request.query.limit <= 1)
      );
      // Allow anonymous users to update the license if they prove they know the PIN
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (request.resource.data.accessPin == resource.data.accessPin && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedByUid', 'lastLoginAt', 'accessPin']) &&
         (resource.data.status == 'pending' || resource.data.usedByUid == request.auth.uid))
      );
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow read, write: if isAdmin();
    }
  }
}
